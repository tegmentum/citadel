{
  "title": "Citadel — Cluster Trust Overview",
  "uid": "citadel-cluster-trust",
  "schemaVersion": 39,
  "tags": ["citadel", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Cluster Trust Score",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "thresholds": { "mode": "absolute",
        "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 0.99 } ] } } },
      "targets": [ { "expr": "citadel_cluster_trust_score", "refId": "A" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Quarantined Nodes",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [ { "expr": "citadel_nodes_quarantined", "refId": "A" } ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Nodes by Trust State",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [ { "expr": "citadel_nodes_by_state", "legendFormat": "{{state}}", "refId": "A" } ]
    },
    {
      "id": 4, "type": "table", "title": "Per-Node Trust",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [ { "expr": "citadel_node_trust_state", "format": "table", "instant": true, "refId": "A" } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Verified Attestation Failures (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [ { "expr": "rate(citadel_tpm_quote_failure_total[5m])", "refId": "A" } ]
    }
  ]
}
