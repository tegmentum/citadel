# Local CI via nektos/act (until the repo is public on GitHub).
# Run:  act            (push event)   |   act -j build-test
#
# A medium image with common build tooling preinstalled.
-P ubuntu-latest=catthehacker/ubuntu:act-latest
# The workflow needs no docker-in-docker, so don't mount the daemon socket into
# the job container (also avoids a mount error with colima's socket path).
--container-daemon-socket -
